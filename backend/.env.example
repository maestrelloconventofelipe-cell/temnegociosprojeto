# ════════════════════════════════════════════════════════════════
# Tem Negócios — Backend Environment Variables
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no Git.
# ════════════════════════════════════════════════════════════════

PORT=3001

# ── Banco de dados ────────────────────────────────────────────
# Supabase Session Pooler (porta 5432, não 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Autenticação JWT ──────────────────────────────────────────
# Gere um novo valor com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Mínimo obrigatório: 32 caracteres
JWT_SECRET=SUBSTITUA_POR_VALOR_GERADO_ACIMA

# ── Criptografia de CPF ───────────────────────────────────────
# Gere um novo valor com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Deve ter EXATAMENTE 64 chars hexadecimais (256 bits)
# ATENCAO: mudar esta chave invalida todos os CPFs ja armazenados!
ENCRYPTION_KEY=SUBSTITUA_POR_64_CHARS_HEX

# ── CORS (obrigatório em produção) ────────────────────────────
# Domínio exato do frontend (sem barra final)
# Exemplo: https://app.temnegocios.com.br
FRONTEND_URL=http://localhost:5173

# ── Ambiente ──────────────────────────────────────────────────
# Valores: development | production
# Em produção: NODE_ENV=production ativa HTTPS redirect e desativa detalhes de erro
NODE_ENV=development

# ── Hostname da API (redirect HTTPS) ─────────────────────────
# Necessário em produção para o redirect HTTP→HTTPS.
# Deve ser o hostname exato da API (sem protocolo, sem barra final).
# Exemplo: api.temnegocios.com.br
# APP_HOST=

# ── Email (reset de senha) ────────────────────────────────────
# Sem estas variáveis, emails de reset vão para o console (só em dev)
SMTP_HOST=smtp.exemplo.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@temnegocios.com.br
SMTP_PASS=sua_senha_smtp
SMTP_FROM=Tem Negocios <noreply@temnegocios.com.br>

# ── Seed (opcional) ───────────────────────────────────────────
# Se definido, usa esta senha ao criar o admin na primeira execução do seed.
# Se não definido, gera senha aleatória automaticamente (recomendado).
# ADMIN_EMAIL=admin@temnegocios.com.br
# ADMIN_SEED_PASSWORD=
